# ============================================================
# SAHABAT — contoh environment
# Salin ke frontend/.env.local dan isi. JANGAN commit .env.local.
# ============================================================

# --- Publik: aman terekspos ke browser ----------------------
# NEXT_PUBLIC_* DI-BUNDLE KE JAVASCRIPT KLIEN dan bisa dibaca siapa pun
# lewat DevTools. Jangan pernah menaruh secret di balik prefix ini.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SAHABAT

# Sekolah demo (dibuat oleh migrasi 002_hardening.sql).
NEXT_PUBLIC_SEKOLAH_DEMO_ID=00000000-0000-0000-0000-000000000001

# --- Server saja: JANGAN pernah diberi prefix NEXT_PUBLIC_ ---

# Melewati RLS sepenuhnya. Bocornya key ini = seluruh laporan bullying
# terbaca. Hanya untuk API route server-side.
SUPABASE_SERVICE_ROLE_KEY=

# Gateway LLM (OpenAI-compatible) — spec §2/§6.
# Hanya dipakai di API route, tidak pernah sampai ke browser.
#
# Tanpa ini sistem TIDAK mati: chatbot balas mode "gangguan" dan klasifikasi
# jadi ai_gagal=true, tapi laporan siswa TETAP masuk ke antrean Guru BK
# (fail-safe, spec §5.4). Yang hilang cuma label otomatisnya.
LLM_GATEWAY_URL=https://chenzk.top/v1/chat/completions
LLM_GATEWAY_KEY=

# PERINGATAN sebelum mengganti model atau menurunkan max_tokens:
# deepseek-v4-* adalah model REASONING. Token "berpikir" masuk ke
# `reasoning_content` dan ikut menghabiskan max_tokens yang sama. Kalau
# anggarannya habis saat model masih berpikir, `content` KOSONG walau HTTP 200
# — dan setiap laporan jadi ai_gagal. Diukur pada tugas klasifikasi kita:
# ~148 token reasoning + ~53 token jawaban. Lihat src/lib/ai/gateway.js.
#
# Alternatif lebih kuat tapi ~3x lebih lambat: deepseek-v4-pro
LLM_MODEL=deepseek-v4-flash

# Pepper untuk hash kode tiket. WAJIB diisi, minimal 32 karakter.
# Bangkitkan: openssl rand -hex 32
#
# PERINGATAN: mengganti pepper membuat SEMUA kode tiket yang sudah beredar
# tidak bisa dilacak lagi — hash-nya tidak akan pernah cocok. Set sekali,
# lalu jaga seperti password database.
TICKET_PEPPER=

# --- Tidak dipakai untuk demo --------------------------------
# ENCRYPTION_SECRET dipakai lib/utils/encryption.js untuk pesan_konseling.
# Fitur itu tidak dibangun untuk demo.
#
# Catatan penting: karena kuncinya dipegang server, itu enkripsi AT-REST,
# BUKAN end-to-end — server bisa mendekripsi isinya. Jangan menyebutnya
# "end-to-end encryption" di proposal, UI, atau saat presentasi.
# ENCRYPTION_SECRET=
